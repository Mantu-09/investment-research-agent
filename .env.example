# =============================================================================
# Investment Research Agent — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# On Vercel: add these in Project Settings → Environment Variables.
# NEVER commit a file containing real API keys to version control.
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Groq API Key — used for all LLM calls (LLaMA 3.3 70B via ChatGroq)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API Key — used for web research and news findings
# Get it at: https://app.tavily.com/home
TAVILY_API_KEY=your_tavily_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Alpha Vantage API Key — used for financial data (P/E, market cap, etc.)
# Free tier: 25 requests/day, 5/min. Premium gives more.
# Get it at: https://www.alphavantage.co/support/#api-key
# Leave blank to skip financial data (agent handles this gracefully).
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Google Gemini API Key — reserved for future use (not currently active)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
